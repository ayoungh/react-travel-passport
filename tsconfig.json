{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "paths": {
      "react-travel-passport": ["./src/index.ts"],
      "react-travel-passport/styles.css": ["./src/styles.css"]
    },
    "declaration": true,
    "noEmit": true
  },
  "include": ["src", "demo", "vite.config.ts", "tsup.config.ts"]
}
