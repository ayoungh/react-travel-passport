{
  "name": "react-travel-passport",
  "version": "0.1.0",
  "description": "A configurable, animated passport book component for React — show the places you've been with country covers, entry & exit stamps, and visa stickers.",
  "keywords": [
    "react",
    "passport",
    "travel",
    "stamps",
    "visa",
    "map",
    "countries",
    "component",
    "3d",
    "book"
  ],
  "license": "MIT",
  "author": "Anthony Young <ayoung93@gmail.com>",
  "homepage": "https://react-travel-passport.vercel.app",
  "bugs": {
    "url": "https://github.com/ayoungh/react-travel-passport/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ayoungh/react-travel-passport"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup && cp src/styles.css dist/styles.css",
    "dev": "vite",
    "demo:build": "vite build",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run typecheck && pnpm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  }
}
